# =============================================================
# Trade Bot - Environment Configuration
# =============================================================
# IMPORTANT: Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================

# --- Polymarket ---
# Your Ethereum private key (from MetaMask: Account Details > Export Private Key)
# WARNING: This gives full control of your wallet. Use a dedicated trading wallet!
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Your wallet address (the public address from MetaMask)
POLYMARKET_WALLET_ADDRESS=0x_your_wallet_address_here

# Polymarket API endpoints (defaults - usually don't need to change)
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

# Chain ID (137 = Polygon mainnet)
POLYMARKET_CHAIN_ID=137

# --- Binance (Phase 2+) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# --- General ---
# Trading mode: paper | live
TRADING_MODE=paper

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
